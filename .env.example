# Copy to .env and fill in. chmod 600 .env. NEVER commit the real file.
# On a server, prefer a secrets manager over a plaintext file (see DEPLOY.md).

KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret

# --- only needed for unattended (headless cron) login ---
KITE_USER_ID=ZA1234
KITE_PASSWORD=your_kite_password
KITE_TOTP_SECRET=BASE32TOTPSECRET   # the secret behind your authenticator QR,
                                    # not the 6-digit code
